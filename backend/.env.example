# NexusNotes — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real keys!

# ── Google Gemini API Key ──────────────────────────────────────────────────
# Get yours free at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# ── Whisper Model Size ─────────────────────────────────────────────────────
# Options: tiny | base | small | medium | large
# 'base' is fastest for local testing. 'small' gives better accuracy.
WHISPER_MODEL=base

# ── Data Directory ─────────────────────────────────────────────────────────
# Where downloaded videos, audio, and keyframes are stored.
DATA_DIR=./data
